{
  "name": "lean-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio",
    "seed": "\"${BUN_BIN:-$HOME/.bun/bin/bun}\" src/db/seed.ts",
    "parse-date": "\"${BUN_BIN:-$HOME/.bun/bin/bun}\" src/parse-date.ts",
    "tools": "\"${BUN_BIN:-$HOME/.bun/bin/bun}\" src/tools/cli.ts",
    "chat": "\"${BUN_BIN:-$HOME/.bun/bin/bun}\" src/chat.ts",
    "evals": "\"${BUN_BIN:-$HOME/.bun/bin/bun}\" test --timeout=120000 --max-concurrency=1 ./evals/skill-routing.eval.ts ./evals/task-resolution.eval.ts ./evals/trajectory.eval.ts ./evals/usage-regression.eval.ts ./evals/output-quality.eval.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@anthropic-ai/sdk": "^0.78.0",
    "@clack/prompts": "^1.1.0",
    "ai": "^6.0.116",
    "chalk": "^5.6.2",
    "chrono-node": "^2.8.4",
    "cli-markdown": "^3.5.1",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.1",
    "gray-matter": "^4.0.3",
    "ora": "^9.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.2.21",
    "@types/node": "^24.5.2",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
